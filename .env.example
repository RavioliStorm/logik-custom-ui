# Copy this file to .env and fill in your values, then run `npm start`.

# --- Proxy-side (read by src/setupProxy.js; Node only, never sent to browser) ---
LOGIK_API_BASE=https://es-test-headless.test.logik.io
LOGIK_AUTH_TOKEN=your-token-here
# Optional. Origin header the API validates. Defaults to LOGIK_API_BASE; set only
# if your tenant expects a different Origin.
# LOGIK_ORIGIN=https://es-test-headless.test.logik.io

# --- Browser-side (must start with REACT_APP_ to reach the app) ---
# Which configurable product to load on startup. Can also be overridden live in
# the UI or via a ?product= URL param without restarting.
REACT_APP_LOGIK_PRODUCT=configurableProduct5
